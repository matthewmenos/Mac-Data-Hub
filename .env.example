# Flask
FLASK_SECRET_KEY=change-me-to-a-random-secret
FLASK_ENV=production

# Admin credentials (stored in env, not DB)
ADMIN_EMAIL=admin@macdatahub.com
ADMIN_PASSWORD=change-me

# Paystack
PAYSTACK_SECRET_KEY=sk_live_xxxx
PAYSTACK_PUBLIC_KEY=pk_live_xxxx

# GigzHub
GIGZHUB_API_KEY=your-gigzhub-api-key

# Cloudflare R2 — shared API token (used for both buckets)
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key-id
R2_SECRET_ACCESS_KEY=your-secret-access-key
R2_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com

# R2 private bucket — databases only (no public access)
R2_BUCKET_NAME=macdatahub-db

# R2 public assets bucket — logos and media (public access enabled)
# R2_ASSETS_PUBLIC_URL is the pub-xxx.r2.dev URL from the bucket's public access settings
R2_ASSETS_BUCKET_NAME=macdatahub-assets
R2_ASSETS_PUBLIC_URL=https://pub-xxxx.r2.dev

# App
APP_URL=https://yourdomain.com
